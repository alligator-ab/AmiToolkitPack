procedure SaveResults() {
    global Results, errors, testCount;

    printf("\n==============================\n");
    printf("Plugin AmiToolkit - AFL Tests\n");
    printf("==============================\n\n");

    printf(Results);

    printf("\n==============================\n");
    printf("Tests: %g passed, %g failed\n", testCount - errors, errors);
    printf("==============================\n");

    for(i = 0; (s = StrExtract(Results, i, '\n')) != ""; ++i)
		GfxTextOut(s, 0, 20*i + 20);
    //GfxTextOut(Results, 5, 20);
}

//GfxSetBkMode(1); // transparent
GfxSelectFont("Consolas", 10);
GfxSetTextColor(colorBlack); GfxSetBkColor(colorWhite);

TestAll();

if (errors > 0) {
    _TRACE("=== AmiToolkit AFL TESTS: FAILED (" + WriteVal(errors) + " errors) ===");
    Results = "=== AmiToolkit AFL TESTS: FAILED (" + errors + " errors) ===\n"+Results;
} else {
    _TRACE("=== AmiToolkit AFL TESTS: ALL PASSED ===");
    Results = "=== AmiToolkit AFL TESTS: ALL PASSED ===\n"+Results;
}

SaveResults();

if (errors > 0) {
    _TRACE("=== AmiToolkit AFL TESTS: FAILED (" + WriteVal(errors) + " errors) ===");
} else {
    _TRACE("=== AmiToolkit AFL TESTS: ALL PASSED ===");
}

_SECTION_END();
